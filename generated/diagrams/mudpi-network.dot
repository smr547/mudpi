digraph mudpi_network {
  graph [
    rankdir="TB",
    splines="polyline",
    overlap=false,
    nodesep=0.5,
    ranksep=1.0,
    pad=0.25,
    labelloc="t",
    label="MudPi Distributed Network",
    fontsize=20,
    fontname="Helvetica"
  ];
  node [fontname="Helvetica", fontsize=10, margin=0.12];
  edge [fontname="Helvetica", fontsize=9];

  subgraph cluster_vpn {
    label=<<B>vpn</B><BR/>vpn.home.arpa<BR/>Overlay 10.8.1.0/24<BR/>Hub 10.8.1.1<BR/>DNS mudpi>;
    style="rounded,dashed";
    penwidth=1.5;
    fontsize=12;
    host_vpn_laptop [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5"><TR><TD ALIGN="CENTER"><B>laptop</B></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10">laptop.vpn.home.arpa</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">VPN 10.8.1.20 (laptop.vpn.home.arpa)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">roaming-client</FONT></TD></TR></TABLE>>, shape=plain, style="filled", fillcolor="white", penwidth=1.0];
    host_reid_mudpi [label=<<TABLE BORDER="2" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5"><TR><TD ALIGN="CENTER"><B>mudpi</B></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10">mudpi.reid.home.arpa</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">LAN 10.1.1.10</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">VPN 10.8.1.1 (mudpi.vpn.home.arpa)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">wireguard-hub • dns • dhcp • ntp-stratum1 • dynamic-dns</FONT></TD></TR></TABLE>>, shape=plain, style="filled", fillcolor="white", penwidth=2.0];
  }

  subgraph cluster_reid {
    label=<<B>reid</B><BR/>reid.home.arpa<BR/>LAN 10.1.1.0/24<BR/>GW 10.1.1.1<BR/>DNS mudpi<BR/>DHCP mudpi>;
    style="rounded";
    penwidth=1.5;
    fontsize=12;
    host_reid_mudpi [label=<<TABLE BORDER="2" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5"><TR><TD ALIGN="CENTER"><B>mudpi</B></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10">mudpi.reid.home.arpa</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">LAN 10.1.1.10</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">VPN 10.8.1.1 (mudpi.vpn.home.arpa)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">wireguard-hub • dns • dhcp • ntp-stratum1 • dynamic-dns</FONT></TD></TR></TABLE>>, shape=plain, style="filled", fillcolor="white", penwidth=2.0];
    host_reid_router [label=<<TABLE BORDER="2" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5"><TR><TD ALIGN="CENTER"><B>router</B></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10">router.reid.home.arpa</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">LAN 10.1.1.1</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">gateway</FONT></TD></TR></TABLE>>, shape=box3d, style="rounded,filled", fillcolor="white", penwidth=1.6];
    host_reid_shorepi [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5"><TR><TD ALIGN="CENTER"><B>shorepi</B></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10">shorepi.reid.home.arpa</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">LAN 10.1.1.20</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">signalk • influxdb • grafana • app-host</FONT></TD></TR></TABLE>>, shape=plain, style="filled", fillcolor="white", penwidth=1.4];
    site_reid [label="10.1.1.0/24", shape=ellipse, style="dashed", penwidth=1.0];
    site_reid -> host_reid_mudpi [arrowhead=none, penwidth=1.0];
    site_reid -> host_reid_router [arrowhead=none, penwidth=1.0];
    site_reid -> host_reid_shorepi [arrowhead=none, penwidth=1.0];
  }

  subgraph cluster_barkingowl {
    label=<<B>barkingowl</B><BR/>barkingowl.home.arpa<BR/>LAN 192.168.0.0/24<BR/>GW 192.168.0.1<BR/>DNS shedpi<BR/>DHCP shedpi>;
    style="rounded";
    penwidth=1.5;
    fontsize=12;
    host_barkingowl_shedpi [label=<<TABLE BORDER="2" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5"><TR><TD ALIGN="CENTER"><B>shedpi</B></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10">shedpi.barkingowl.home.arpa</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">LAN 192.168.0.10</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">VPN 10.8.1.30 (shedpi.vpn.home.arpa)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">dns • dhcp • farm-server</FONT></TD></TR></TABLE>>, shape=plain, style="filled", fillcolor="white", penwidth=2.0];
    host_barkingowl_weatherstation [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="4"><TR><TD ALIGN="CENTER"><B>weatherstation</B></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10">weatherstation.barkingowl.home.arpa</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">LAN 192.168.0.50</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">weather</FONT></TD></TR></TABLE>>, shape=plain, style="filled", fillcolor="white", penwidth=1.2];
    site_barkingowl [label="192.168.0.0/24", shape=ellipse, style="dashed", penwidth=1.0];
    site_barkingowl -> host_barkingowl_shedpi [arrowhead=none, penwidth=1.0];
    site_barkingowl -> host_barkingowl_weatherstation [arrowhead=none, penwidth=1.0];
  }

  subgraph cluster_trilogy {
    label=<<B>trilogy</B><BR/>trilogy.home.arpa<BR/>LAN 192.168.98.0/24<BR/>GW 192.168.98.1<BR/>DNS boatdns<BR/>DHCP boatdns>;
    style="rounded";
    penwidth=1.5;
    fontsize=12;
    host_trilogy_boatdns [label=<<TABLE BORDER="2" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5"><TR><TD ALIGN="CENTER"><B>boatdns</B></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10">boatdns.trilogy.home.arpa</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">LAN 192.168.98.10</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">VPN 10.8.1.40 (boatdns.vpn.home.arpa)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">dns • dhcp</FONT></TD></TR></TABLE>>, shape=plain, style="filled", fillcolor="white", penwidth=2.0];
    host_trilogy_signalk [label=<<TABLE BORDER="1" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5"><TR><TD ALIGN="CENTER"><B>signalk</B></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10">signalk.trilogy.home.arpa</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">LAN 192.168.98.20</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">signalk</FONT></TD></TR></TABLE>>, shape=plain, style="filled", fillcolor="white", penwidth=1.4];
    site_trilogy [label="192.168.98.0/24", shape=ellipse, style="dashed", penwidth=1.0];
    site_trilogy -> host_trilogy_boatdns [arrowhead=none, penwidth=1.0];
    site_trilogy -> host_trilogy_signalk [arrowhead=none, penwidth=1.0];
  }

  subgraph cluster_testboat {
    label=<<B>testboat</B><BR/>testboat.home.arpa<BR/>LAN 192.168.97.0/24<BR/>GW 192.168.97.1<BR/>DNS labdns<BR/>DHCP labdns>;
    style="rounded";
    penwidth=1.5;
    fontsize=12;
    host_testboat_labdns [label=<<TABLE BORDER="2" CELLBORDER="1" CELLSPACING="0" CELLPADDING="5"><TR><TD ALIGN="CENTER"><B>labdns</B></TD></TR><TR><TD ALIGN="CENTER"><FONT POINT-SIZE="10">labdns.testboat.home.arpa</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">LAN 192.168.97.10</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">VPN 10.8.1.50 (labdns.vpn.home.arpa)</FONT></TD></TR><TR><TD ALIGN="LEFT"><FONT POINT-SIZE="10">dns • dhcp</FONT></TD></TR></TABLE>>, shape=plain, style="filled", fillcolor="white", penwidth=2.0];
    site_testboat [label="192.168.97.0/24", shape=ellipse, style="dashed", penwidth=1.0];
    site_testboat -> host_testboat_labdns [arrowhead=none, penwidth=1.0];
  }

  host_reid_mudpi -> host_barkingowl_shedpi [dir=both, style=dashed, penwidth=1.4, label="WireGuard"];
  host_reid_mudpi -> host_trilogy_boatdns [dir=both, style=dashed, penwidth=1.4, label="WireGuard"];
  host_reid_mudpi -> host_testboat_labdns [dir=both, style=dashed, penwidth=1.4, label="WireGuard"];
  host_reid_mudpi -> host_vpn_laptop [dir=both, style=dashed, penwidth=1.4, label="WireGuard"];
  host_reid_mudpi -> host_barkingowl_shedpi [style=dotted, penwidth=1.0, label="DNS forward barkingowl.home.arpa"];
  host_reid_mudpi -> host_testboat_labdns [style=dotted, penwidth=1.0, label="DNS forward testboat.home.arpa"];
  host_reid_mudpi -> host_trilogy_boatdns [style=dotted, penwidth=1.0, label="DNS forward trilogy.home.arpa"];
}
